  "faq": [
    {
      "q": "Z jakim wyprzedzeniem zamawiać tort?",
      "a": "Standardowe torty przyjmujemy z ok. 3–4 dniowym wyprzedzeniem, a bardziej rozbudowane projekty (śluby) — z większym zapasem czasu."
    },
    {
      "q": "Czy macie wypieki wegańskie lub bezglutenowe?",
      "a": "Tak, regularnie przygotowujemy propozycje wegańskie i bezglutenowe. Przy zamówieniu tortu dopasujemy recepturę do potrzeb."
    },
    {
      "q": "Czy dowozicie zamówienia?",
      "a": "Większe zamówienia i torty możemy dowieźć na wskazany adres — szczegóły ustalamy indywidualnie."
    },
    {
      "q": "Jak mogę zapłacić?",
